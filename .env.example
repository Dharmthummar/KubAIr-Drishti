# Gemini API configuration for chatbot and optional PDF OCR
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-3.1-flash-lite-preview
GEMINI_OCR_MODEL=gemini-3.1-flash-lite-preview

# PDF processing
FAST_MODE=1
ENABLE_PDF_OCR=0

# Flask configuration
FLASK_ENV=production
FLASK_APP=app.py
PORT=5000
